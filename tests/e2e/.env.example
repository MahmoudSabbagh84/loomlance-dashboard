# Credentials for the Playwright happy-path E2E test.
# Use a dedicated throwaway user on a NON-production Supabase project — the test
# creates a client, a project, and a draft invoice on each run.
E2E_USER_EMAIL=test@loomlance.local
E2E_USER_PASSWORD=password123

# Optional: point the test at a non-default base URL (defaults to http://localhost:5173)
# PLAYWRIGHT_BASE_URL=http://localhost:5173
